    "NSMotionUsageDescription" : {
      "comment" : "Permission usage description",
      "localizations" : {
        "de-DE" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CycleHUD nutzt das Barometer, um deinen Höhengewinn während einer Fahrt genau zu messen, und den Beschleunigungssensor, um einen Sturz zu erkennen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CycleHUD uses the barometer to measure your elevation gain accurately, and the accelerometer to detect a crash during a ride."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CycleHUD uses the barometer to measure your elevation gain accurately, and the accelerometer to detect a crash during a ride."
          }
        },
        "en-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CycleHUD uses the barometer to measure your elevation gain accurately, and the accelerometer to detect a crash during a ride."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CycleHUD usa el barómetro para medir con precisión tu desnivel durante una ruta y el acelerómetro para detectar una caída."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CycleHUD utilise le baromètre pour mesurer précisément votre dénivelé pendant une sortie, et l’accéléromètre pour détecter une chute."
          }
        },
        "it-IT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CycleHUD usa il barometro per misurare con precisione il dislivello durante un’uscita e l’accelerometro per rilevare un incidente."
          }
        }
      }
    }
