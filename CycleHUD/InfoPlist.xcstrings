{
  "sourceLanguage": "en",
  "strings": {
    "NSBluetoothAlwaysUsageDescription": {
      "localizations": {
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD connects to your rear radar and speed/cadence sensors over Bluetooth to show approaching vehicles and your riding data."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD connects to your rear radar and speed/cadence sensors over Bluetooth to show approaching vehicles and your riding data."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD verbindet sich über Bluetooth mit deinem Heckradar und Geschwindigkeits-/Trittfrequenzsensoren, um herannahende Fahrzeuge und deine Fahrdaten anzuzeigen."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD se connecte en Bluetooth à votre radar arrière et à vos capteurs de vitesse/cadence pour afficher les véhicules qui approchent et vos données."
          }
        },
        "it-IT": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD si connette via Bluetooth al radar posteriore e ai sensori di velocità/cadenza per mostrare i veicoli in avvicinamento e i tuoi dati."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD se conecta por Bluetooth a tu radar trasero y a los sensores de velocidad/cadencia para mostrar los vehículos que se acercan y tus datos."
          }
        }
      },
      "comment": "Permission usage description"
    },
    "NSHealthShareUsageDescription": {
      "localizations": {
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD reads your heart rate and body metrics to estimate calories burned during a ride."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD reads your heart rate and body metrics to estimate calories burned during a ride."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD liest deine Herzfrequenz und Körperdaten, um die verbrannten Kalorien während einer Fahrt zu schätzen."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD lit votre fréquence cardiaque et vos données corporelles pour estimer les calories brûlées pendant une sortie."
          }
        },
        "it-IT": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD legge la frequenza cardiaca e i dati corporei per stimare le calorie bruciate durante un'uscita."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD lee tu frecuencia cardíaca y datos corporales para estimar las calorías quemadas durante una ruta."
          }
        }
      },
      "comment": "Permission usage description"
    },
    "NSHealthUpdateUsageDescription": {
      "localizations": {
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD saves your ride as a cycling workout, including distance, calories and route, to Apple Health."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD saves your ride as a cycling workout, including distance, calories and route, to Apple Health."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD speichert deine Fahrt als Radtraining mit Distanz, Kalorien und Route in Apple Health."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD enregistre votre sortie comme entraînement de vélo, avec distance, calories et itinéraire, dans Apple Santé."
          }
        },
        "it-IT": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD salva la tua uscita come allenamento di ciclismo, con distanza, calorie e percorso, in Apple Salute."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD guarda tu ruta como entrenamiento de ciclismo, con distancia, calorías y recorrido, en Apple Salud."
          }
        }
      },
      "comment": "Permission usage description"
    },
    "NSLocationAlwaysAndWhenInUseUsageDescription": {
      "localizations": {
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD uses GPS to record your speed and distance during a ride, including while the screen is off."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD uses GPS to record your speed and distance during a ride, including while the screen is off."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD nutzt GPS, um deine Geschwindigkeit und Distanz während der Fahrt aufzuzeichnen, auch bei ausgeschaltetem Bildschirm."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD utilise le GPS pour enregistrer votre vitesse et votre distance pendant une sortie, même écran éteint."
          }
        },
        "it-IT": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD utilizza il GPS per registrare velocità e distanza durante un'uscita, anche con lo schermo spento."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD usa el GPS para registrar tu velocidad y distancia durante una ruta, incluso con la pantalla apagada."
          }
        }
      },
      "comment": "Permission usage description"
    },
    "NSLocationWhenInUseUsageDescription": {
      "localizations": {
        "en-GB": {
          "stringUnit": {
            "state": "translated",
