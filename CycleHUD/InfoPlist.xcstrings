          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD nutzt GPS, um deine Geschwindigkeit und Distanz während der Fahrt aufzuzeichnen, auch bei ausgeschaltetem Bildschirm."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD utilise le GPS pour enregistrer votre vitesse et votre distance pendant une sortie, même écran éteint."
          }
        },
        "it-IT": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD usa il GPS per registrare velocità e distanza durante un'uscita, anche con lo schermo spento."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD usa el GPS para registrar tu velocidad y distancia durante una ruta, incluso con la pantalla apagada."
          }
        }
      },
      "comment": "Permission usage description"
    },
    "NSMotionUsageDescription": {
      "localizations": {
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD uses the barometer to measure your elevation gain accurately during a ride."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD uses the barometer to measure your elevation gain accurately during a ride."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD nutzt das Barometer, um deinen Höhengewinn während einer Fahrt genau zu messen."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD utilise le baromètre pour mesurer précisément votre dénivelé pendant une sortie."
          }
        },
        "it-IT": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD usa il barometro per misurare con precisione il dislivello durante un'uscita."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "CycleHUD usa el barómetro para medir con precisión tu desnivel durante una ruta."
          }
        }
      },
      "comment": "Permission usage description"
    }
  },
  "version": "1.0"
}