<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>CycleHUD</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>CycleHUD connects to your rear radar and speed/cadence sensors over Bluetooth to show approaching vehicles and your riding data.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>CycleHUD reads your heart rate and body metrics to estimate calories burned during a ride.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>CycleHUD saves your ride as a cycling workout, including distance, calories and route, to Apple Health.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>CycleHUD uses GPS to record your speed and distance during a ride, including while the screen is off.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>CycleHUD uses GPS to record your speed and distance during a ride, including while the screen is off.</string>
	<key>NSMotionUsageDescription</key>
	<string>CycleHUD uses the barometer to measure your elevation gain accurately during a ride.</string>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>bluetooth-central</string>
		<string>audio</string>
	</array>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string></string>
	</dict>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>bluetooth-le</string>
		<string>location-services</string>
		<string>gps</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
</dict>
</plist>
