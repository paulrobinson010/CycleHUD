    "Your weight is used with Apple Watch heart rate to estimate calories. Read from Apple Health when available; without a weight, calories aren't shown." : {
      "localizations" : {
        "de-DE" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein Gewicht wird mit der Apple-Watch-Herzfrequenz zur Kalorienschätzung genutzt. Wird, wenn verfügbar, aus Apple Health gelesen; ohne Gewicht werden keine Kalorien angezeigt."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your weight is used with Apple Watch heart rate to estimate calories. Read from Apple Health when available; without a weight, calories aren't shown."
          }
        },
        "en-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your weight is used with Apple Watch heart rate to estimate calories. Read from Apple Health when available; without a weight, calories aren't shown."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu peso se usa con la frecuencia cardíaca del Apple Watch para estimar las calorías. Se lee de Apple Salud cuando está disponible; sin peso, no se muestran."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre poids est utilisé avec la fréquence cardiaque de l'Apple Watch pour estimer les calories. Lu depuis Apple Santé si disponible ; sans poids, les calories ne s'affichent pas."
          }
        },
        "it-IT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il tuo peso è usato con la frequenza cardiaca dell'Apple Watch per stimare le calorie. Letto da Apple Salute se disponibile; senza peso, le calorie non vengono mostrate."
          }
        }
      }
    }
  },
  "version" : "1.1"
