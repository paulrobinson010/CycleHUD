        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ %@ still connected after your ride. Switch %@ off to save battery."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ %@ nach deiner Fahrt noch verbunden. Schalte %@ aus, um Akku zu sparen."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ %@ encore connecté(s) après votre sortie. Éteignez %@ pour économiser la batterie."
          }
        },
        "it-IT": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ %@ ancora connesso/i dopo l'uscita. Spegni %@ per risparmiare batteria."
