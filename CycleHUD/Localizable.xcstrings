    "Each ride is saved to Apple Health. Your weight is used with Apple Watch heart rate to estimate calories — without a weight, calories aren't shown. Read from Apple Health when available.": {
      "localizations": {
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Each ride is saved to Apple Health. Your weight is used with Apple Watch heart rate to estimate calories — without a weight, calories aren't shown. Read from Apple Health when available."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Each ride is saved to Apple Health. Your weight is used with Apple Watch heart rate to estimate calories — without a weight, calories aren't shown. Read from Apple Health when available."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "Jede Fahrt wird in Apple Health gespeichert. Dein Gewicht wird mit der Apple-Watch-Herzfrequenz zur Kalorienschätzung genutzt — ohne Gewicht werden keine Kalorien angezeigt. Wird, wenn verfügbar, aus Apple Health gelesen."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaque sortie est enregistrée dans Apple Santé. Votre poids est utilisé avec la fréquence cardiaque de l'Apple Watch pour estimer les calories — sans poids, les calories ne s'affichent pas. Lu depuis Apple Santé si disponible."
          }
        },
        "it-IT": {
          "stringUnit": {
            "state": "translated",
            "value": "Ogni uscita viene salvata in Apple Salute. Il tuo peso è usato con la frequenza cardiaca dell'Apple Watch per stimare le calorie — senza peso, le calorie non vengono mostrate. Letto da Apple Salute se disponibile."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada ruta se guarda en Apple Salud. Tu peso se usa con la frecuencia cardíaca del Apple Watch para estimar las calorías; sin peso, no se muestran. Se lee de Apple Salud cuando está disponible."
          }
        }
      }
    },
