    "%@ %@ still connected after your ride. Switch %@ off to save battery.": {
      "localizations": {
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ %@ still connected after your ride. Switch %@ off to save battery."
          }
