    "Choose the app's language, or follow your device. Some text (such as system permission prompts) updates after you reopen the app." : {
      "localizations" : {
        "de-DE" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wähle die Sprache der App oder folge deinem Gerät. Manche Texte (etwa System-Berechtigungsdialoge) werden erst nach erneutem Öffnen der App aktualisiert."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose the app's language, or follow your device. Some text (such as system permission prompts) updates after you reopen the app."
          }
        },
        "en-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose the app's language, or follow your device. Some text (such as system permission prompts) updates after you reopen the app."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige el idioma de la app o sigue tu dispositivo. Algunos textos (como los avisos de permisos del sistema) se actualizan al reabrir la app."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisissez la langue de l'app ou suivez votre appareil. Certains textes (comme les demandes d'autorisation système) se mettent à jour après réouverture de l'app."
          }
        },
        "it-IT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scegli la lingua dell'app o segui il dispositivo. Alcuni testi (come le richieste di autorizzazione di sistema) si aggiornano dopo aver riaperto l'app."
          }
        }
      }
    },
