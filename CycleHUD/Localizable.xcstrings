    "When your heart rate reaches this, the heart-rate readout turns red and a paired Apple Watch double-buzzes — repeating every 30 seconds while it stays high." : {
      "localizations" : {
        "de-DE" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn deine Herzfrequenz diesen Wert erreicht, wird die Anzeige rot und eine gekoppelte Apple Watch vibriert doppelt — alle 30 Sekunden, solange sie hoch bleibt."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When your heart rate reaches this, the heart-rate readout turns red and a paired Apple Watch double-buzzes — repeating every 30 seconds while it stays high."
          }
        },
        "en-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When your heart rate reaches this, the heart-rate readout turns red and a paired Apple Watch double-buzzes — repeating every 30 seconds while it stays high."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando tu frecuencia cardíaca alcanza este valor, la lectura se vuelve roja y un Apple Watch emparejado vibra dos veces, repitiéndose cada 30 segundos mientras siga alta."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque votre fréquence cardiaque atteint ce seuil, l'affichage devient rouge et une Apple Watch jumelée vibre deux fois — toutes les 30 secondes tant qu'elle reste élevée."
          }
        },
        "it-IT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando la frequenza cardiaca raggiunge questo valore, il dato diventa rosso e un Apple Watch abbinato vibra due volte — ogni 30 secondi finché resta alta."
          }
        }
      }
    },
