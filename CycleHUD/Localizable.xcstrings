    "Re-shows the welcome screen you saw when you first opened the app. Close Settings (or reopen the app) to see it. Your rides and other settings are kept." : {
      "localizations" : {
        "de-DE" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zeigt den Begrüßungsbildschirm erneut, den du beim ersten Öffnen der App gesehen hast. Schließe die Einstellungen (oder öffne die App neu), um ihn zu sehen. Deine Fahrten und übrigen Einstellungen bleiben erhalten."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Re-shows the welcome screen you saw when you first opened the app. Close Settings (or reopen the app) to see it. Your rides and other settings are kept."
          }
        },
        "en-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Re-shows the welcome screen you saw when you first opened the app. Close Settings (or reopen the app) to see it. Your rides and other settings are kept."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vuelve a mostrar la pantalla de bienvenida que viste al abrir la app por primera vez. Cierra Ajustes (o reabre la app) para verla. Tus rutas y demás ajustes se conservan."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Réaffiche l'écran d'accueil vu à la première ouverture de l'app. Fermez les Réglages (ou rouvrez l'app) pour le voir. Vos sorties et autres réglages sont conservés."
          }
        },
        "it-IT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mostra di nuovo la schermata di benvenuto vista al primo avvio dell'app. Chiudi le Impostazioni (o riapri l'app) per vederla. Le tue uscite e le altre impostazioni vengono mantenute."
          }
        }
      }
    },
