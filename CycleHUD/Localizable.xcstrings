    "Distance and closing speed are measured by the radar (~2 readings/second). Estimated vehicle speed adds your own speed onto the closing speed and is an approximation." : {
      "localizations" : {
        "de-DE" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Distanz und Annäherungsgeschwindigkeit werden vom Radar gemessen (~2 Messungen/Sekunde). Die geschätzte Fahrzeuggeschwindigkeit addiert deine eigene Geschwindigkeit und ist ein Näherungswert."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Distance and closing speed are measured by the radar (~2 readings/second). Estimated vehicle speed adds your own speed onto the closing speed and is an approximation."
          }
        },
        "en-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Distance and closing speed are measured by the radar (~2 readings/second). Estimated vehicle speed adds your own speed onto the closing speed and is an approximation."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La distancia y la velocidad de aproximación las mide el radar (~2 lecturas/segundo). La velocidad estimada del vehículo suma tu propia velocidad y es una aproximación."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La distance et la vitesse d'approche sont mesurées par le radar (~2 mesures/seconde). La vitesse estimée du véhicule ajoute votre propre vitesse et reste approximative."
          }
        },
        "it-IT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Distanza e velocità di avvicinamento sono misurate dal radar (~2 letture/secondo). La velocità stimata del veicolo aggiunge la tua velocità ed è un'approssimazione."
          }
        }
      }
    },
