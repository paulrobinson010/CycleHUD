          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sirve para convertir las vueltas de rueda en velocidad. Se usa el GPS si no hay sensor de velocidad."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
