    "Restores the original tiles (three rows, nothing above the radar) and the display and alert settings. Your units, language, weight, wheel size, emergency contact, paired sensors and ride history are kept." : {
      "localizations" : {
        "de-DE" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stellt die ursprünglichen Kacheln (drei Reihen, nichts über dem Radar) sowie die Anzeige- und Hinweis-Einstellungen wieder her. Deine Einheiten, Sprache, Gewicht, Radumfang, Notfallkontakt, gekoppelte Sensoren und Fahrten bleiben erhalten."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restores the original tiles (three rows, nothing above the radar) and the display and alert settings. Your units, language, weight, wheel size, emergency contact, paired sensors and ride history are kept."
          }
        },
        "en-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restores the original tiles (three rows, nothing above the radar) and the display and alert settings. Your units, language, weight, wheel size, emergency contact, paired sensors and ride history are kept."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restaura las casillas originales (tres filas, nada encima del radar) y los ajustes de pantalla y avisos. Tus unidades, idioma, peso, circunferencia de rueda, contacto de emergencia, sensores emparejados y rutas se conservan."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restaure les tuiles d’origine (trois rangées, rien au-dessus du radar) ainsi que les réglages d’affichage et d’alertes. Vos unités, langue, poids, circonférence de roue, contact d’urgence, capteurs jumelés et sorties sont conservés."
          }
        },
        "it-IT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ripristina le schede originali (tre righe, niente sopra il radar) e le impostazioni di visualizzazione e avvisi. Unità, lingua, peso, circonferenza della ruota, contatto di emergenza, sensori abbinati e uscite restano invariati."
          }
        }
      }
    },
