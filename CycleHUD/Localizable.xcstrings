          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "Dient zur Umrechnung der Radumdrehungen in Geschwindigkeit. Ohne Geschwindigkeitssensor wird GPS verwendet."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sert à convertir les tours de roue en vitesse. Le GPS est utilisé sans capteur de vitesse."
          }
        },
        "it-IT": {
          "stringUnit": {
            "state": "translated",
            "value": "Serve a convertire i giri della ruota in velocità. Senza sensore di velocità si usa il GPS."
