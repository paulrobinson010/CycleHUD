    "Dark mode" : {
      "extractionState" : "stale",
      "localizations" : {
        "de-DE" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dunkelmodus"
          }
        },
        "en-GB" : {
          "stringUnit" : {
