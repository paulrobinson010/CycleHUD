        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ %@ aún conectado(s) tras tu ruta. Apaga %@ para ahorrar batería."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ %@ encore connecté(s) après votre sortie. Éteignez %@ pour économiser la batterie."
          }
        },
        "it-IT" : {
