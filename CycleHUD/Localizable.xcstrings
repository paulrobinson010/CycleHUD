    "Used to convert wheel revolutions into speed. GPS is used when no speed sensor is connected." : {
      "localizations" : {
        "de-DE" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dient zur Umrechnung der Radumdrehungen in Geschwindigkeit. Ohne Geschwindigkeitssensor wird GPS verwendet."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Used to convert wheel revolutions into speed. GPS is used when no speed sensor is connected."
          }
        },
        "en-US" : {
          "stringUnit" : {
            "state" : "translated",
